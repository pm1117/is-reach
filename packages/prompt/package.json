{
  "name": "@is-reach/prompt",
  "version": "0.1.0",
  "private": true,
  "description": "Claude API 呼び出しとプロンプトインジェクション対策の唯一の実装点（E2/E6/E7/E8/E11）。サンドイッチ構造のプロンプト組み立て・external_data タグ生成・サニタイズ S1〜S5・出力検証 V1〜V6。外部サイトアクセス・DB アクセスはしない（basic-design 2.1）。",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm run typecheck && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@is-reach/shared": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
