{
  "name": "@is-reach/api",
  "version": "0.1.0",
  "private": true,
  "description": "API サーバー + ジョブワーカー（basic-design 2.1 / D1）。Hono ベース。Supabase Auth JWT 検証 → テナントコンテキスト → 認可（design-detail 2.4）、RLS 接続規約（E14 のアプリ側）、pg-boss キューアダプタ（D5/E1）、監査ログ記録（E16）。LLM 直接呼び出し禁止（packages/prompt 経由のみ）。",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm run typecheck && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@is-reach/analysis": "workspace:*",
    "@is-reach/crawler": "workspace:*",
    "@is-reach/prompt": "workspace:*",
    "@is-reach/shared": "workspace:*",
    "hono": "^4.8.0",
    "jose": "^6.0.0",
    "pg": "^8.16.0",
    "pg-boss": "^12.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
